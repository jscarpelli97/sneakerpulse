# --- Data providers ---

# KicksDB free (€0 / 1k req/mo) — optional fallback while StockX official is pending
# https://kicks.dev/register — key must show as Active
KICKSDB_API_KEY=

# Page views stay on the committed offline catalog unless this is "1".
# Daily snapshot jobs call KicksDB directly and ignore this flag.
KICKSDB_LIVE_READS=

# Official StockX Developer API (preferred once approved)
# Portal: https://developer.stockx.com/
STOCKX_API_KEY=
STOCKX_CLIENT_ID=
STOCKX_CLIENT_SECRET=
# Must match the redirect URI registered in the StockX developer app
STOCKX_REDIRECT_URI=https://sneakerpulse.vercel.app/api/stockx/callback
# Filled after OAuth (visit /api/stockx/auth once credentials are set)
STOCKX_ACCESS_TOKEN=
STOCKX_REFRESH_TOKEN=

# Optional: when set, GET /api/status with header x-status-token returns cache/fetch details
STATUS_TOKEN=

# Plus waitlist — interest emails go here (FormSubmit) unless WAITLIST_WEBHOOK_URL is set
PLUS_INTEREST_EMAIL=jscarpelli97@gmail.com
# Optional Zapier / Make / Discord webhook instead of FormSubmit
WAITLIST_WEBHOOK_URL=
