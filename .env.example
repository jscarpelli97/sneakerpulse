# --- Cloud accounts (Portfolio + Wardrobe sync) ---
# Neon Postgres via Vercel Marketplace (recommended):
#   1. Open https://vercel.com/jscarpelli97/~/integrations/accept-terms/neon?source=cli
#   2. Accept Neon terms, then: npx vercel integration add neon -n spi-markets-db
#   3. npx vercel env pull .env.local
#   4. DATABASE_URL=… node scripts/migrate-users.mjs
DATABASE_URL=
# Long random secret for session cookies (required in production)
AUTH_JWT_SECRET=

# --- Data providers ---

# KicksDB free (€0 / 1k req/mo) — optional fallback while StockX official is pending
# https://kicks.dev/register — key must show as Active
KICKSDB_API_KEY=

# Page views stay on the committed offline catalog unless this is "1".
# Daily snapshot jobs call KicksDB directly and ignore this flag.
KICKSDB_LIVE_READS=

# Official StockX Developer API (preferred once approved)
# Portal: https://developer.stockx.com/
STOCKX_API_KEY=
STOCKX_CLIENT_ID=
STOCKX_CLIENT_SECRET=
# Must match the redirect URI registered in the StockX developer app
STOCKX_REDIRECT_URI=https://spimarkets.com/api/stockx/callback
# Filled after OAuth (visit /api/stockx/auth once credentials are set)
STOCKX_ACCESS_TOKEN=
STOCKX_REFRESH_TOKEN=

# Optional: when set, GET /api/status with header x-status-token returns cache/fetch details
STATUS_TOKEN=

# Plus waitlist — interest emails go here (FormSubmit) unless WAITLIST_WEBHOOK_URL is set
PLUS_INTEREST_EMAIL=
# Optional Zapier / Make / Discord webhook instead of FormSubmit
WAITLIST_WEBHOOK_URL=

# --- Plus membership (Bitcoin + Lightning via OpenNode) ---
# Keep NEXT_PUBLIC_PLUS_PUBLIC unset/false until StockX API access is clear.
# Set to 1 to re-enable Plus marketing, catalog soft-lock, and checkout.
NEXT_PUBLIC_PLUS_PUBLIC=
# https://opennode.com — create API key; use OPENNODE_ENV=dev for testnet keys
OPENNODE_API_KEY=
OPENNODE_ENV=dev
PLUS_PRICE_USD=10
PLUS_TERM_DAYS=30
# Random secret used to sign Plus membership cookies
PLUS_JWT_SECRET=
NEXT_PUBLIC_SITE_URL=https://spimarkets.com
# Server-only inbox for /api/contact (never shown on the site).
# Falls back to PLUS_INTEREST_EMAIL when unset. Required for the About form.
# CONTACT_INBOX_EMAIL=

# eBay comps on market pages (off by default). Set NEXT_PUBLIC_EBAY_PUBLIC=1 to show.
# Live asks need Browse API credentials from https://developer.ebay.com/
# Without credentials the panel still shows an eBay search link (link-only mode).
NEXT_PUBLIC_EBAY_PUBLIC=
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
# production | sandbox
EBAY_ENV=production
EBAY_MARKETPLACE_ID=EBAY_US
